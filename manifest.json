{
  "name": "CSE 2027 — Study Planner",
  "short_name": "StudyApp",
  "id": "/STUDY-app/",
  "description": "Offline-first UPSC/CSE Study Planner with analytics, streaks, habits and full offline support",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "orientation": "portrait",
  "background_color": "#08090e",
  "theme_color": "#6366f1",
  "lang": "en",
  "dir": "ltr",
  "categories": ["education", "productivity"],
  "prefer_related_applications": false,
  "related_applications": [],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+studyapp",
      "url": "./index.html?action=%s"
    }
  ],
  "icons": [
    { "src": "icons/icon-72.png",          "sizes": "72x72",   "purpose": "any" },
    { "src": "icons/icon-72-maskable.png",  "sizes": "72x72",   "purpose": "maskable" },
    { "src": "icons/icon-96.png",          "sizes": "96x96",   "purpose": "any" },
    { "src": "icons/icon-96-maskable.png",  "sizes": "96x96",   "purpose": "maskable" },
    { "src": "icons/icon-128.png",          "sizes": "128x128", "purpose": "any" },
    { "src": "icons/icon-128-maskable.png", "sizes": "128x128", "purpose": "maskable" },
    { "src": "icons/icon-144.png",          "sizes": "144x144", "purpose": "any" },
    { "src": "icons/icon-144-maskable.png", "sizes": "144x144", "purpose": "maskable" },
    { "src": "icons/icon-152.png",          "sizes": "152x152", "purpose": "any" },
    { "src": "icons/icon-152-maskable.png", "sizes": "152x152", "purpose": "maskable" },
    { "src": "icons/icon-192.png",          "sizes": "192x192", "purpose": "any" },
    { "src": "icons/icon-192-maskable.png", "sizes": "192x192", "purpose": "maskable" },
    { "src": "icons/icon-384.png",          "sizes": "384x384", "purpose": "any" },
    { "src": "icons/icon-384-maskable.png", "sizes": "384x384", "purpose": "maskable" },
    { "src": "icons/icon-512.png",          "sizes": "512x512", "purpose": "any" },
    { "src": "icons/icon-512-maskable.png", "sizes": "512x512", "purpose": "maskable" }
  ],
  "screenshots": [],
  "shortcuts": [
    {
      "name": "Start Session",
      "short_name": "Timer",
      "url": "./index.html#sessions",
      "icons": [{ "src": "icons/icon-96.png", "sizes": "96x96" }]
    },
    {
      "name": "Today's Tasks",
      "short_name": "Tasks",
      "url": "./index.html#today",
      "icons": [{ "src": "icons/icon-96.png", "sizes": "96x96" }]
    }
  ]
}
